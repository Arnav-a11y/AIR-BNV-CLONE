<% if (success && success.length) { %>
  <div class="flash-container position-fixed start-50 translate-middle-x"
      style="top: 20px; z-index: 1100; max-width: 380px; width: 100%;">

      <div class="alert alert-success alert-dismissible fade show shadow d-flex align-items-center px-3 py-2 small"
          role="alert" data-autohide="true" style="border-radius: 10px;">

          <svg class="bi flex-shrink-0 me-2" role="img" aria-label="Success:" width="18" height="18">
              <use xlink:href="#check-circle-fill" />
          </svg>

          <div class="flex-grow-1 text-center fw-semibold">
              <%= Array.isArray(success) ? success[0] : success %>
          </div>

          <button type="button" class="btn-close ms-1" data-bs-dismiss="alert" aria-label="Close"
              style="font-size: 0.5rem;"></button>
      </div>
  </div>

<% } else if (error && error.length) { %>

  <div class="flash-container position-fixed start-50 translate-middle-x"
      style="top: 20px; z-index: 1100; max-width: 380px; width: 100%;">

      <div class="alert alert-danger alert-dismissible fade show shadow d-flex align-items-center px-3 py-2 small"
          role="alert" data-autohide="true" style="border-radius: 10px;">

          <svg class="bi flex-shrink-0 me-2" role="img" aria-label="Error:" width="18" height="18">
              <use xlink:href="#check-circle-fill" />
          </svg>

          <div class="flex-grow-1 text-center fw-semibold">
              <%= Array.isArray(error) ? error[0] : error %>
          </div>

          <button type="button" class="btn-close ms-1" data-bs-dismiss="alert" aria-label="Close"
              style="font-size: 0.5rem;"></button>
      </div>
  </div>

<% } %>
