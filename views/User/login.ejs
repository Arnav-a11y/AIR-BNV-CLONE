<% layout("/layouts/boilerplate") %>

    <div class="container form-container mt-5 mb-5">
        <h2 class="text-center mb-4 fw-bold">LogIn User !  </h2>
        <form action="/login" method="post" class=" needs-validation custom-form shadow-lg p-4 rounded" novalidate>
            
         <div class="mb-3">
                <label class="form-label fw-semibold">Username: </label>
                <input type="text" name="username" class="form-control" placeholder="Enter a username" required>
                <div class="invalid-feedback">
                    Enter valid username
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Password: </label>
                <input type="text" name="password" class="form-control" placeholder="Enter a password" required>
                <div class="invalid-feedback">
                    Enter valid password
                </div>
            </div>
            
            <button class="btn btn-dark w-100 py-2 fw-bold submit-btn">Submit</button>

        </form>

        </div>