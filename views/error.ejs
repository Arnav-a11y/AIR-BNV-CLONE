<% layout("layouts/boilerplate") %>

<section class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center p-4 shadow rounded bg-light">
            <h1 class="display-5 text-danger mb-3">⚠️ <%= status || 500 %> Error</h1>
            
            <p class="lead mb-4">
                <%= message || "Something went wrong." %>
            </p>

            <a href="/listings" class="btn btn-primary px-4">Back to Listings</a>

            <p class="mt-4 text-muted">
                If this keeps happening, please try again later.
            </p>
        </div>
    </div>
</section>
