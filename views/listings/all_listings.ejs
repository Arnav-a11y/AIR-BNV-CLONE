<% layout("/layouts/boilerplate") %>
    <body>
        <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-2 g-4">
            <% for (let listing of listings) { %>
                <div class="col">
                    <a href="/listings/<%= listing._id %>" class="text-decoration-none listing-link">
                        <div class="card h-100 shadow-sm">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="not available"
                                style="height: 20rem; object-fit: cover;">
                            <div class="card-img-overlay">
                                <h5 class="card-text">
                                    <%=listing.description%>
                                </h5>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title text-dark">
                                    <%= listing.title %>
                                </h5>
                                <p class="card-text text-muted">
                                    <%= listing.location %>
                                </p>
                                <p class="card-text fw-bold">
                                    <%= listing.country %>
                                </p>
                                <button class="btn btn-dark w-100">
                                    ₹<%= Number(listing.price).toLocaleString("en-IN") %> / Night
                                </button>
                            </div>
                        </div>
                    </a>
                </div>
                <% } %>
        </div>


    </body>